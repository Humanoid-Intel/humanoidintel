# humanoidintel.ai — Environment Variables
# Copy to .env.local and fill in values

# Required for AI content generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional — for social monitoring
TWITTER_BEARER_TOKEN=...

# Optional — for news aggregation
GOOGLE_NEWS_API_KEY=...

# Optional — for auto-publishing via git
GITHUB_TOKEN=ghp_...

# Optional — for newsletter integration
BUTTONDOWN_API_KEY=...

# Analytics
PLAUSIBLE_DOMAIN=humanoidintel.ai

# Agent configuration
PUBLISH_MODE=draft          # draft | auto | full
CONFIDENCE_THRESHOLD=0.8    # 0.0 - 1.0

# Notifications (Slack/Discord webhook URL)
NOTIFICATION_WEBHOOK=https://hooks.slack.com/...
